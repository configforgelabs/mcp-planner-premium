{
  "name": "mcp-planner-premium",
  "version": "1.0.0",
  "description": "Self-hosted MCP server for Microsoft Planner Premium structural writes via Dataverse PSS V2 APIs (delegated user context).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mcp-planner-premium": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "test": "LOG_LEVEL=silent vitest run",
    "e2e": "tsx test/e2e/runner.ts",
    "e2e:acceptance": "tsx test/e2e/pmOpsLive.ts",
    "e2e:acceptance:rebuild": "REBUILD_SEED=1 tsx test/e2e/pmOpsLive.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jose": "^5.9.6",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@anthropic-ai/sdk": "^0.53.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
